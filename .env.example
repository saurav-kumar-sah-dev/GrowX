# Copy to .env in this folder and fill in values. (Never commit .env)

NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Required — MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/growx

# Required — JWT for user sessions (use a long random string in production)
SECRET_KEY=

# Admin routes — set in production (seed script also uses ADMIN_PASSWORD)
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional — Gmail (app password); leave empty to disable outbound email
MAIL_USER=
MAIL_PASS=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Optional — Cloudinary uploads
CLOUD_NAME=
API_KEY=
API_SECRET=

# Optional — Firebase Admin (server)
FIREBASE_PROJECT_ID=
# Paste key with \n for newlines, or real newlines in multiline .env value
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
# Same value as Firebase "Web API Key" (Project settings). Required for POST /api/v1/user/google.
FIREBASE_WEB_API_KEY=

# Optional — set true for local testing without sending emails
SKIP_EMAIL_VERIFICATION=false
