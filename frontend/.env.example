# Copy to frontend/.env for local dev. Vite reads VITE_* at build/dev time.

# Backend API (default in repo is port 5000 — match root .env PORT)
VITE_API_BASE=http://localhost:5000/api
VITE_USER_API=http://localhost:5000/api/v1/user
VITE_JOB_API=http://localhost:5000/api/v1/job
VITE_APPLICATION_API=http://localhost:5000/api/v1/application
VITE_COMPANY_API=http://localhost:5000/api/v1/company
VITE_CONTACT_API=http://localhost:5000/api/contact
VITE_KANBAN_API=http://localhost:5000/api/tasks
VITE_KANBAN_BOARD_API=http://localhost:5000/api/tasks
VITE_AI_CHAT_API=http://localhost:5000/api/v1/ai-chat
VITE_LEARNING_API=http://localhost:5000/api/v1/learning
VITE_QUIZ_API=http://localhost:5000/api/v1/quiz
VITE_QUIZ_RESULT_API=http://localhost:5000/api/v1/quiz-result
VITE_ATS_API=http://localhost:5000/api/v1/ats
VITE_RESUME_API=http://localhost:5000/api/resumes
VITE_INTERNSHIP_API=http://localhost:5000/api/v1/internship
VITE_SAVED_JOB_API=http://localhost:5000/api/v1/saved-job
VITE_CATEGORY_API=http://localhost:5000/api/v1/category

# Client Firebase (get from Firebase console)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google OAuth client ID (Google Cloud console)
VITE_GOOGLE_CLIENT_ID=
